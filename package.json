{
  "name": "stanza-sync",
  "version": "0.1.0",
  "description": "Web app connecting poets with editors using AI and Duotrope",
  "main": "backend/server.js",
  "scripts": {
    "start": "node backend/server.js",
    "dev": "nodemon backend/server.js",
    "build:css": "npx tailwindcss -i ./frontend/styles.css -o ./frontend/output.css --minify",
    "watch:css": "npx tailwindcss -i ./frontend/styles.css -o ./frontend/output.css --watch"
  },
  "keywords": [
    "poetry",
    "duotrope",
    "ai",
    "submission"
  ],
  "author": "Hazel",
  "license": "MIT",
  "dependencies": {
    "@tailwindcss/cli": "^4.2.1",
    "axios": "^1.4.0",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "sqlite3": "^5.1.6"
  },
  "devDependencies": {
    "nodemon": "^2.0.22",
    "tailwindcss": "^4.2.1"
  }
}
